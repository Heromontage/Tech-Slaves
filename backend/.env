# ─────────────────────────────────────────────────────────────────────────────
# SentinelFlow — environment variables
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENV=development                    # development | staging | production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=sentinelflow
POSTGRES_PASSWORD=sentinelflow
POSTGRES_HOST=localhost            # use "localhost" when running outside Docker
POSTGRES_PORT=5432
POSTGRES_DB=sentinelflow

# Connection pool
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=1800

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687        # use "bolt://localhost:7687" outside Docker
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinelflow
NEO4J_DATABASE=neo4j               # "neo4j" for Community Edition
